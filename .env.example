# LLM プロバイダ設定（このファイルを .env にコピーして値を設定）
# .env は .gitignore 済み（コミットされない）

# プロバイダ: openai（既定） | gemini | vertex
LLM_PROVIDER=vertex

# モデル名（省略時はプロバイダ既定）
# openai→gpt-4o-mini / gemini→gemini-3.5-flash / vertex→google/gemini-3.5-flash（google/ は自動付与）
LLM_MODEL=gemini-3.5-flash

# --- Vertex / Agent Platform (OpenAI 互換 + ADC OAuth) を使う場合（推奨）---
# 事前に `gcloud auth application-default login` を実行しておく（API キーは不要）
GCP_PROJECT=your-gcp-project-id
LLM_LOCATION=global

# --- Gemini (AI Studio / OpenAI 互換エンドポイント) を使う場合 ---
# LLM_PROVIDER=gemini
# 取得済みの Gemini API キーを設定
# GEMINI_API_KEY=your-gemini-api-key
# 既定の base_url を上書きする場合のみ設定（通常は不要）
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- OpenAI を使う場合 ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# 共通の上書き用（プロバイダ非依存で指定したい場合）
# LLM_API_KEY=...
# LLM_BASE_URL=...
