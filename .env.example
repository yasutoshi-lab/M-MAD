# LLM プロバイダ設定（このファイルを .env にコピーして値を設定）
# .env は .gitignore 済み（コミットされない）

# プロバイダ: openai（既定） | gemini
LLM_PROVIDER=gemini

# モデル名（省略時はプロバイダ既定: openai→gpt-4o-mini / gemini→gemini-3.5-flash）
LLM_MODEL=gemini-3.5-flash

# --- Gemini (AI Studio / OpenAI 互換エンドポイント) を使う場合 ---
# 取得済みの Gemini API キーを設定
GEMINI_API_KEY=your-gemini-api-key
# 既定の base_url を上書きする場合のみ設定（通常は不要）
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- OpenAI を使う場合 ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# 共通の上書き用（プロバイダ非依存で指定したい場合）
# LLM_API_KEY=...
# LLM_BASE_URL=...
