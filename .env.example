# LLM プロバイダ設定（このファイルを .env にコピーして値を設定）
# .env は .gitignore 済み（コミットされない）

# --- 共通設定 ---
# プロバイダ: openai | gemini | vertex（既定・推奨） | anthropic
LLM_PROVIDER=vertex
# モデル名（省略時はプロバイダ既定を使用）
LLM_MODEL=gemini-3.5-flash
# API キー（openai / gemini / anthropic で使用。vertex は ADC 認証のため不要）
# LLM_API_KEY=your-api-key
# OpenAI 互換エンドポイントの上書き（省略時はプロバイダ既定を自動適用。通常不要）
# LLM_BASE_URL=

# --- Vertex を使う場合（既定・推奨。ADC 認証で API キー不要）---
# 事前に `gcloud auth application-default login` を実行しておく
GCP_PROJECT=your-gcp-project-id
LLM_LOCATION=global

# --- 各プロバイダの設定例（LLM_PROVIDER / LLM_MODEL / LLM_API_KEY を設定）---
# gemini    : LLM_PROVIDER=gemini    / LLM_MODEL=gemini-3.5-flash / LLM_API_KEY=<Gemini API キー>
# openai    : LLM_PROVIDER=openai    / LLM_MODEL=gpt-4o-mini      / LLM_API_KEY=<OpenAI API キー>
# anthropic : LLM_PROVIDER=anthropic / LLM_MODEL=claude-haiku-4-5 / LLM_API_KEY=<Anthropic API キー>
